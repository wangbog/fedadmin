# Development server(flask run) app entry point
FLASK_APP=run.py

# Flask development settings
FLASK_CONFIG=development
FLASK_DEBUG=1

# Security (development-friendly default values)
# Generate secure keys using: openssl rand -hex 32
SECRET_KEY=your-dev-secret-key-minimum-32-characters-long
SECURITY_PASSWORD_SALT=your-dev-salt-minimum-32-characters-long

# Federation (development-friendly default values)
FEDERATION_NAME=samplefed
FEDERATION_PUBLIC_FILES_URL=https://samplefed.example.com

# Federation metadata regeneration settings
# Time to run daily metadata regeneration (UTC). Format: "hour:minute" (e.g., "2:00")
METADATA_REGENERATION_TIME=2:00

# Grace time (in seconds) for async metadata regeneration tasks before they are skipped
METADATA_REGENERATION_MISFIRE_GRACE_TIME=60

# Time interval for checking eduGAIN updates (hours)
EDUGAIN_CHECK_INTERVAL=1

# Mail server settings for password recovery
MAIL_SERVER=smtp.resend.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=resend
MAIL_PASSWORD=your-api-key
MAIL_DEFAULT_SENDER=onboarding@resend.dev
# Set to True to suppress sending emails during development (useful for testing)
MAIL_SUPPRESS_SEND=False

# Flask-Security email settings
SECURITY_SEND_PASSWORD_CHANGE_EMAIL=True
SECURITY_SEND_PASSWORD_RESET_EMAIL=True

# Logging settings
LOG_FILE=/var/log/fedadmin/app.log
LOG_LEVEL=DEBUG