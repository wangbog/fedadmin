# Flask production settings (run.py is the entry point)
FLASK_APP=run.py
FLASK_CONFIG=production
FLASK_DEBUG=0

# Security (REQUIRED - must change!)
# Generate secure keys using: openssl rand -hex 32
SECRET_KEY=your-production-secret-key-minimum-32-characters-long
SECURITY_PASSWORD_SALT=your-production-salt-minimum-32-characters-long

# Federation name (REQUIRED - must change!)
# Will be used in certificate (CN field) and metadata (ID and Name fields)
FEDERATION_NAME=samplefed

# Mail server settings for password recovery and new-user password setup links
MAIL_SERVER=smtp.your-domain.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@your-domain.com
MAIL_PASSWORD=your-email-password
MAIL_DEFAULT_SENDER=your-email@your-domain.com

# Flask-Security email settings
SECURITY_SEND_PASSWORD_CHANGE_EMAIL=True
SECURITY_SEND_PASSWORD_RESET_EMAIL=True

# Logging settings
LOG_FILE=/var/log/fedadmin/app.log
LOG_LEVEL=INFO
